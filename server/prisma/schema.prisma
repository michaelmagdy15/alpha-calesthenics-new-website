// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())
  email       String       @unique
  name        String?
  status      UserStatus   @default(PENDING) // "PENDING", "PAID"
  stripeId    String?      // Optional: to map webhook events
  assessment  Assessment?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Assessment {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  height      Float    // Value in cm
  weight      Float    // Value in kg
  goals       String   // Textual description of goals
  driveLink   String   // Google drive / WhatsApp backup link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum UserStatus {
  PENDING
  PAID
}
